{
  "uid": "app-health",
  "title": "Application Health – Blue vs Green",
  "schemaVersion": 36,
  "version": 2,
  "refresh": "10s",
  "panels": [
    {
      "type": "timeseries",
      "title": "Traffic Split",
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{pod=~\"app-blue.*\"}[1m]))",
          "legendFormat": "blue"
        },
        {
          "expr": "sum(rate(http_requests_total{pod=~\"app-green.*\"}[1m]))",
          "legendFormat": "green"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Error Rate",
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{status=~\"5..\",pod=~\"app-blue.*\"}[5m])) / sum(rate(http_requests_total{pod=~\"app-blue.*\"}[5m]))",
          "legendFormat": "blue"
        },
        {
          "expr": "sum(rate(http_requests_total{status=~\"5..\",pod=~\"app-green.*\"}[5m])) / sum(rate(http_requests_total{pod=~\"app-green.*\"}[5m]))",
          "legendFormat": "green"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Latency P95",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket{pod=~\"app-blue.*\"}[5m])))",
          "legendFormat": "blue"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket{pod=~\"app-green.*\"}[5m])))",
          "legendFormat": "green"
        }
      ]
    }
  ]
}
